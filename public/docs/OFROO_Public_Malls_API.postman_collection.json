{
  "info": {
    "_postman_id": "ofroo-public-malls-v1",
    "name": "OFROO — Public Malls API",
    "description": "مسارات المولات العامة (بدون توكن): قائمة مولات، تجار داخل مول، ومراجع لعروض التاجر.\n\nBase URL: {{base_url}} — استخدم `http://localhost:8000/api` أو `http://localhost:8000/api/mobile` للموبايل.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "mall_id",
      "value": "1"
    },
    {
      "key": "merchant_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Public Malls",
      "item": [
        {
          "name": "List active malls",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/malls?language=ar&per_page=30",
              "host": ["{{base_url}}"],
              "path": ["malls"],
              "query": [
                { "key": "language", "value": "ar", "description": "ar | en" },
                { "key": "per_page", "value": "30" }
              ]
            },
            "description": "GET /api/malls — نفس المسار تحت الموبايل: /api/mobile/malls"
          }
        },
        {
          "name": "Merchants in mall (optional category filter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/malls/{{mall_id}}/merchants?language=ar&per_page=15&category_id=",
              "host": ["{{base_url}}"],
              "path": ["malls", "{{mall_id}}", "merchants"],
              "query": [
                { "key": "language", "value": "ar" },
                { "key": "per_page", "value": "15" },
                { "key": "category_id", "value": "", "description": "فلتر اختياري: category_id للتاجر" }
              ]
            },
            "description": "تجار مرتبطون بالمول (صف التاجر أو فرع في المول). الموبايل: /api/mobile/malls/{id}/merchants"
          }
        },
        {
          "name": "Merchant detail (public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/merchants/{{merchant_id}}?language=ar",
              "host": ["{{base_url}}"],
              "path": ["merchants", "{{merchant_id}}"],
              "query": [{ "key": "language", "value": "ar" }]
            },
            "description": "للموبايل استبدل base_url بـ .../api/mobile"
          }
        },
        {
          "name": "Merchant offers (public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/merchants/{{merchant_id}}/offers?language=ar&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["merchants", "{{merchant_id}}", "offers"],
              "query": [
                { "key": "language", "value": "ar" },
                { "key": "per_page", "value": "15" }
              ]
            },
            "description": "عروض التاجر بعد الاختيار من قائمة المول"
          }
        },
        {
          "name": "Offers filtered by mall",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/offers?mall={{mall_id}}&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["offers"],
              "query": [
                { "key": "mall", "value": "{{mall_id}}", "description": "معرّف المول (offer.mall_id)" },
                { "key": "per_page", "value": "15" }
              ]
            },
            "description": "قائمة عروض موسومة بمول معيّن (اختياري للتطبيق)"
          }
        }
      ]
    }
  ]
}
